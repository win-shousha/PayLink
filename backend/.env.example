# Application
NODE_ENV=development
APP_NAME=PayLink
APP_DESCRIPTION=Plateforme Africaine de Paiement Numérique
APP_URL=http://localhost:3000
APP_PORT=3000

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=paylink_user
DATABASE_PASSWORD=paylink_secure_password_123
DATABASE_NAME=paylink_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key
JWT_REFRESH_EXPIRATION=30d

# 2FA
TOTP_WINDOW=1
TOTP_ISSUER=PayLink

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@paylink.app

# SMS
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=your_account_sid
SMS_AUTH_TOKEN=your_auth_token
SMS_PHONE_NUMBER=+1234567890

# Firebase
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# Payments - Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLIC_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# Payments - Flutterwave
FLUTTERWAVE_SECRET_KEY=your_secret_key
FLUTTERWAVE_PUBLIC_KEY=your_public_key

# Payments - Paystack
PAYSTACK_SECRET_KEY=your_secret_key

# OpenAI (For AI Assistant)
OPENAI_API_KEY=sk-your_api_key

# Admin
ADMIN_EMAIL=codjia55@gmail.com
ADMIN_NAME=Codjia Winner
ADMIN_PHONE=+2290161069793

# Currency & Location
CURRENCY=XOF
COUNTRY=BJ
TIMEZONE=Africa/Porto-Novo
LOCALE=fr_BJ

# Languages
DEFAULT_LANGUAGE=fr
SUPPORTED_LANGUAGES=fr,en

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/paylink.log

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:5173,http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
